/** index.wxss — Dark Theme **/

/*
 * Design Tokens
 * bg-page:       #0a0a0c
 * bg-elevated:   #141416
 * bg-card:       #1e1e22
 * bg-card-hover: #252529
 * border:        rgba(255,255,255,0.06)
 * text-primary:  #f2f2f7
 * text-secondary:#98989d
 * text-muted:    #636366
 * accent-green:  #32d74b
 * btn-secondary: #2c2c2e
 * btn-disabled:  #3a3a3c
 */

page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #0a0a0c;
  color: #f2f2f7;
}

.page {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

/* ===== 顶部区域 ===== */

.top-section {
  flex-shrink: 0;
  padding: 24rpx;
  background-color: #141416;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.nearest-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.nearest-placeholder {
  flex: 1;
  font-size: 28rpx;
  color: #636366;
  text-align: center;
  padding: 24rpx 0;
  transition: color 0.3s ease;
}

.nearest-card-item {
  flex: 1;
  padding: 20rpx 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  background-color: #1e1e22;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.35);
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
  transition: background-color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
}

.nearest-item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #f2f2f7;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

.nearest-item-line {
  font-size: 22rpx;
  color: #98989d;
  margin-top: 8rpx;
}

.nearest-item-dist {
  font-size: 24rpx;
  color: #636366;
  margin-top: 6rpx;
}

.progress-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.progress-block {
  flex: 1;
  min-width: 0;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.progress-title {
  font-size: 24rpx;
  color: #98989d;
  transition: color 0.3s ease;
}

.progress-num {
  font-size: 22rpx;
  color: #f2f2f7;
  transition: color 0.3s ease;
}

.progress-bar {
  height: 12rpx;
  background-color: #2c2c2e;
  border-radius: 6rpx;
  margin-top: 10rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, #28a745, #32d74b);
  border-radius: 6rpx;
  transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.checkin-actions {
  display: flex;
  gap: 20rpx;
}

.btn-checkin-nearest {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
  color: #1c1c1e;
  font-size: 26rpx;
  font-weight: bold;
  height: 72rpx;
  line-height: normal;
  white-space: nowrap;
  border-radius: 36rpx;
  margin: 0 !important;
  padding: 0 16rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: background-color 0.3s ease, color 0.3s ease,
              transform 0.2s ease, box-shadow 0.3s ease, opacity 0.3s ease;
}

.btn-checkin-nearest:active {
  transform: scale(0.98);
  background-color: #f2f2f2;
}

.btn-checkin-nearest[disabled] {
  background-color: #2c2c2e;
  color: #cccccc;
  opacity: 0.6;
  box-shadow: none;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.btn-refresh {
  flex-shrink: 0;
  background-color: #2c2c2e;
  color: #98989d;
  font-size: 26rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  padding: 0 28rpx;
  margin: 0 !important;
  transition: background-color 0.3s ease, color 0.3s ease,
              transform 0.2s ease, box-shadow 0.3s ease, opacity 0.3s ease;
}

.btn-refresh:active {
  transform: scale(0.98);
  background-color: #3a3a3c;
  color: #f2f2f7;
}

/* ===== 主体区域 ===== */

.body-section {
  flex: 1;
  display: flex;
  min-height: 0;
  overflow: hidden;
}

.sidebar {
  width: 176rpx;
  flex-shrink: 0;
  height: 100%;
  background-color: #141416;
  border-right: 1rpx solid rgba(255, 255, 255, 0.06);
}

.sidebar-item {
  padding: 28rpx 16rpx;
  font-size: 28rpx;
  color: #98989d;
  text-align: center;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
  border-left: 4rpx solid transparent;
  transition: background-color 0.3s ease, color 0.3s ease,
              border-left 0.3s ease, font-weight 0.2s ease;
}

.sidebar-item.active {
  background-color: rgba(50, 215, 75, 0.08);
  color: #32d74b;
  font-weight: 600;
  border-left-color: #32d74b;
}

.main-content {
  flex: 1;
  height: 100%;
  padding: 20rpx;
  box-sizing: border-box;
  background-color: #0a0a0c;
}

/* ===== 站点列表 ===== */

.station-item {
  display: flex;
  align-items: center;
  background-color: #1e1e22;
  margin-bottom: 12rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.25);
  transition: background-color 0.3s ease, border-color 0.3s ease,
              box-shadow 0.3s ease;
}

.station-item.checked-card {
  flex-direction: column;
  align-items: stretch;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  background-color: #252529;
  border-color: rgba(50, 215, 75, 0.2);
  box-shadow: 0 4rpx 20rpx rgba(50, 215, 75, 0.08);
}

.checked-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  min-width: 0;
}

.checked-row-meta {
  margin-top: 2rpx;
  gap: 12rpx;
}

.name-txt {
  font-size: 30rpx;
  color: #f2f2f7;
  transition: color 0.3s ease;
}

.ellipsis {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.checked-tag {
  font-size: 20rpx;
  color: #32d74b;
  margin-left: 12rpx;
  background-color: rgba(50, 215, 75, 0.12);
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  line-height: 1.4;
}

.meta-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.check-time {
  font-size: 22rpx;
  color: #636366;
  flex-shrink: 0;
}

.memo-btn {
  font-size: 22rpx;
  color: #98989d;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.btn-undo-mini {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: auto;
  max-width: 150rpx;
  flex-shrink: 0;
  background-color: #2c2c2e;
  color: #98989d;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  height: auto;
  line-height: 1.4;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  margin: 0 !important;
  box-sizing: border-box;
  transition: background-color 0.3s ease, color 0.3s ease,
              transform 0.2s ease, border-color 0.3s ease;
}

.btn-undo-mini:active {
  transform: scale(0.98);
  background-color: #3a3a3c;
  color: #f2f2f7;
  border-color: rgba(255, 255, 255, 0.12);
}

.empty-tip {
  text-align: center;
  color: #636366;
  font-size: 28rpx;
  padding: 60rpx 0;
}

/* ===== 成就图鉴：底部触发条 + 浮层 ===== */

.achievement-trigger {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(30, 30, 34, 0.98), rgba(20, 20, 22, 1));
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.45);
}

.achievement-trigger-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #f2f2f7;
}

.achievement-trigger-chevron {
  color: #98989d;
  font-size: 28rpx;
}

.achievement-overlay {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(20, 20, 20, 0.95);
  -webkit-backdrop-filter: blur(10px);
  backdrop-filter: blur(10px);
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.35s ease, visibility 0.35s ease;
}

.achievement-overlay.is-open {
  opacity: 1;
  visibility: visible;
}

.achievement-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 88vh;
  max-height: 100%;
  border-radius: 32rpx 32rpx 0 0;
  background: rgba(20, 20, 20, 0.98);
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 -16rpx 48rpx rgba(0, 0, 0, 0.5);
}

.achievement-overlay.is-open .achievement-panel {
  transform: translateY(0);
}

.achievement-panel-header {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx 20rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.achievement-panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #f2f2f7;
}

.achievement-panel-count {
  font-size: 24rpx;
  color: #98989d;
}

.achievement-panel-close {
  margin-left: auto;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #98989d;
  background-color: #2c2c2e;
  border-radius: 50%;
  transition: background-color 0.2s ease, color 0.2s ease;
}

.achievement-panel-close:active {
  background-color: #3a3a3c;
  color: #f2f2f7;
}

.achievement-panel-scroll {
  flex: 1;
  min-height: 0;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.achievement-category-card {
  margin: 16rpx 24rpx;
  border-radius: 20rpx;
  background-color: #1e1e22;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  overflow: hidden;
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}

.achievement-category-header {
  display: flex;
  align-items: center;
  padding: 24rpx;
  gap: 12rpx;
}

.achievement-category-title {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 500;
  color: #f2f2f7;
}

.achievement-category-meta {
  font-size: 22rpx;
  color: #636366;
  flex-shrink: 0;
}

.achievement-category-arrow {
  flex-shrink: 0;
  width: 16rpx;
  height: 16rpx;
  margin-left: 8rpx;
  border-right: 3rpx solid #98989d;
  border-bottom: 3rpx solid #98989d;
  transform: rotate(-45deg);
  transition: transform 0.3s ease;
}

.achievement-category-arrow.is-expanded {
  transform: rotate(45deg);
}

.achievement-category-body {
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}

.achievement-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  padding: 16rpx 20rpx 20rpx;
  box-sizing: border-box;
}

.achievement-card {
  position: relative;
  box-sizing: border-box;
  padding: 20rpx 16rpx;
  border-radius: 16rpx;
  background-color: #252529;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}

.achievement-card.locked {
  opacity: 0.85;
}

.achievement-card.unlocked {
  opacity: 1;
  border-color: rgba(50, 215, 75, 0.35);
  animation: ach-breathe 2.4s ease-in-out infinite;
}

.achievement-card-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  border-radius: 16rpx;
  background: rgba(10, 10, 12, 0.55);
  pointer-events: none;
}

@keyframes ach-breathe {
  0%, 100% {
    box-shadow: 0 0 0 rgba(50, 215, 75, 0.15);
  }
  50% {
    box-shadow: 0 0 24rpx rgba(50, 215, 75, 0.35);
  }
}

.ach-emoji {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.ach-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #f2f2f7;
  text-align: center;
}

.ach-desc {
  font-size: 20rpx;
  color: #636366;
  margin-top: 6rpx;
  text-align: center;
  line-height: 1.4;
}

.achievement-card.unlocked .ach-desc {
  color: #98989d;
}

/* ===== 成就图鉴 · 开发者序言悬浮球 ===== */

.dev-fab {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  z-index: 9999;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  -webkit-backdrop-filter: blur(5px);
  backdrop-filter: blur(5px);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 36rpx;
  line-height: 1;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.35);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  transition: transform 0.2s ease, background 0.2s ease;
}

.dev-fab:active {
  transform: scale(0.92);
  background: rgba(255, 255, 255, 0.16);
}

/* ===== 开发者序言 ===== */

.dev-overlay {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
  background: rgba(15, 15, 15, 0.92);
  -webkit-backdrop-filter: blur(12px);
  backdrop-filter: blur(12px);
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.dev-overlay.is-open {
  opacity: 1;
  visibility: visible;
}

.dev-panel {
  width: 100%;
  max-width: 640rpx;
  max-height: 78vh;
  display: flex;
  flex-direction: column;
  border-radius: 28rpx;
  background: rgba(20, 20, 22, 0.98);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 24rpx 64rpx rgba(0, 0, 0, 0.55);
  transform: scale(0.96);
  transition: transform 0.3s ease;
  overflow: hidden;
}

.dev-overlay.is-open .dev-panel {
  transform: scale(1);
}

.dev-panel-header {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx 20rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.dev-panel-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #f2f2f7;
  text-shadow: 0 0 24rpx rgba(255, 255, 255, 0.08);
}

.dev-panel-close {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #98989d;
  background-color: #2c2c2e;
  border-radius: 50%;
  transition: background-color 0.2s ease, color 0.2s ease;
}

.dev-panel-close:active {
  background-color: #3a3a3c;
  color: #f2f2f7;
}

.dev-panel-scroll {
  flex: 1;
  min-height: 0;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
}

.dev-preface-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.75;
  color: rgba(242, 242, 247, 0.92);
  letter-spacing: 0.5rpx;
  white-space: pre-wrap;
  text-shadow: 0 0 24rpx rgba(255, 255, 255, 0.06);
}

.dev-panel-footer {
  flex-shrink: 0;
  padding: 16rpx 32rpx 28rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.dev-btn-dismiss {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #f2f2f7;
  background: linear-gradient(180deg, rgba(44, 44, 46, 0.95), rgba(30, 30, 34, 1));
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  transition: background 0.25s ease, transform 0.2s ease;
}

.dev-btn-dismiss:active {
  transform: scale(0.98);
  background: #3a3a3c;
}
